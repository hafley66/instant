{
  "manifest_version": 3,
  "name": "instant spy",
  "version": "0.1.0",
  "description": "Streams tab navigation, text selections, and copies to the local instant app (127.0.0.1:8787).",
  "permissions": ["tabs"],
  "host_permissions": ["http://127.0.0.1:8787/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
