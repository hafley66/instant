{
  "openapi": "3.0.3",
  "info": { "title": "Instant HTTP APIs", "version": "1.0.0" },
  "servers": [{ "url": "http://127.0.0.1:7748", "description": "local ghcache daemon" }],
  "paths": {
    "/worktrees": {
      "get": {
        "operationId": "worktrees",
        "responses": {
          "200": {
            "description": "Current git worktree snapshot",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/WorktreeRow" } }
              }
            }
          }
        }
      }
    },
    "/events": {
      "get": {
        "operationId": "events",
        "responses": {
          "200": {
            "description": "ghcache change stream",
            "content": { "text/event-stream": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/config": {
      "get": {
        "operationId": "activityConfig",
        "servers": [{ "url": "http://127.0.0.1:8787" }],
        "responses": {
          "200": {
            "description": "Authoritative browser extraction rules",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ServerConfig" } } }
          }
        }
      }
    },
    "/heartbeat": {
      "post": {
        "operationId": "activityHeartbeat",
        "servers": [{ "url": "http://127.0.0.1:8787" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WatcherHeartbeat" } } }
        },
        "responses": {
          "200": {
            "description": "Extension watcher status recorded",
            "content": { "text/plain": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/ingest": {
      "post": {
        "operationId": "activityIngest",
        "servers": [{ "url": "http://127.0.0.1:8787" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/IngestEvent" } } }
        },
        "responses": {
          "200": {
            "description": "Event accepted or filtered",
            "content": { "text/plain": { "schema": { "type": "string" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WorktreeRow": {
        "type": "object",
        "required": ["origin", "clone", "worktree", "branch", "head", "is_main", "dirty"],
        "properties": {
          "origin": { "type": "string" },
          "clone": { "type": "string" },
          "worktree": { "type": "string" },
          "branch": { "type": "string" },
          "head": { "type": "string" },
          "is_main": { "type": "boolean" },
          "dirty": { "type": "boolean" }
        }
      },
      "Rule": {
        "type": "object",
        "required": ["id", "host", "mode"],
        "properties": {
          "id": { "type": "string" },
          "host": { "type": "string" },
          "url": { "type": "string" },
          "mode": { "type": "string", "enum": ["textnodes", "selector", "netcapture"] },
          "selector": { "type": "string" },
          "regex": { "type": "string" },
          "captures": { "type": "object", "additionalProperties": { "type": "string" } },
          "request": {
            "type": "object",
            "properties": {
              "methods": { "type": "array", "items": { "type": "string" } },
              "url": { "type": "string" }
            }
          },
          "response": {
            "type": "object",
            "properties": { "extract": { "type": "object", "additionalProperties": { "type": "string" } } }
          },
          "emit": {
            "type": "object",
            "required": ["stream"],
            "properties": {
              "stream": { "type": "string" },
              "schema": { "$ref": "#/components/schemas/JsonSchema" }
            }
          },
          "schedule": {
            "oneOf": [
              { "type": "string", "enum": ["passive"] },
              {
                "type": "object",
                "required": ["intervalMin"],
                "properties": {
                  "intervalMin": { "type": "number" },
                  "effects": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/RuleEffect" }
                  }
                }
              }
            ]
          },
          "enabled": { "type": "boolean" }
        }
      },
      "WatcherHeartbeat": {
        "type": "object",
        "required": ["revision", "rulesCount"],
        "properties": {
          "revision": { "type": "integer" },
          "rulesCount": { "type": "integer" }
        }
      },
      "RuleEffect": {
        "type": "object",
        "required": ["op"],
        "properties": {
          "id": { "type": "string" },
          "op": { "type": "string" },
          "input": {}
        }
      },
      "ServerConfig": {
        "type": "object",
        "required": ["rules"],
        "properties": {
          "revision": { "type": "integer" },
          "rules": { "type": "array", "items": { "$ref": "#/components/schemas/Rule" } }
        }
      },
      "JsonSchema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "type": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "properties": { "type": "object", "additionalProperties": { "$ref": "#/components/schemas/JsonSchema" } },
          "items": { "$ref": "#/components/schemas/JsonSchema" },
          "minimum": { "type": "number" },
          "maximum": { "type": "number" },
          "format": { "type": "string" }
        }
      },
      "ActivityEvent": {
        "type": "object",
        "required": ["kind", "url", "title", "text"],
        "properties": {
          "kind": { "type": "string" },
          "url": { "type": "string" },
          "title": { "type": "string" },
          "text": { "type": "string" }
        }
      },
      "RuleMatchEvent": {
        "type": "object",
        "required": ["type", "ruleId", "url", "ts", "matches"],
        "properties": {
          "type": { "type": "string", "enum": ["rulematch"] },
          "ruleId": { "type": "string" },
          "url": { "type": "string" },
          "ts": { "type": "integer" },
          "matches": { "type": "array", "items": { "type": "object", "additionalProperties": {} } },
          "stream": { "type": "string" },
          "schema": { "$ref": "#/components/schemas/JsonSchema" }
        }
      },
      "EditorEvent": {
        "type": "object",
        "required": ["type", "event", "path", "ts"],
        "properties": {
          "type": { "type": "string", "enum": ["editor"] },
          "event": { "type": "string", "enum": ["focus", "cursor", "save"] },
          "path": { "type": "string" },
          "languageId": { "type": "string" },
          "workspace": { "type": "string" },
          "line": { "type": "integer" },
          "ts": { "type": "integer" }
        }
      },
      "IngestEvent": {
        "oneOf": [
          { "$ref": "#/components/schemas/ActivityEvent" },
          { "$ref": "#/components/schemas/RuleMatchEvent" },
          { "$ref": "#/components/schemas/EditorEvent" }
        ]
      }
    }
  }
}
