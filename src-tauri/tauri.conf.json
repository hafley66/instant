{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "instant",
  "version": "0.1.0",
  "identifier": "com.instant.summon",
  "build": {
    "beforeDevCommand": "corepack pnpm@10.12.4 run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm@10.12.4 run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "instant",
        "width": 820,
        "height": 540,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true,
        "dragDropEnabled": false
      },
      {
        "label": "dropcatcher",
        "url": "dropcatcher.html",
        "width": 820,
        "height": 540,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
