    "@tanstack/react-virtual": "^3.14.3",
    "@tanstack/virtual-core": "^3.17.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^6.6.1",
    "dockview-core": "^6.6.1",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^3.0.6",
    "shiki": "^4.2.0",
    "tinykeys": "^4.0.0",
