{
  "name": "instant",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.4",
  "type": "module",
  "scripts": {
    "api:generate": "node scripts/generate-api.mjs && node scripts/generate-native.mjs",
    "api:check": "node scripts/generate-api.mjs --check && node scripts/generate-native.mjs --check",
    "dev": "vite",
    "build": "node scripts/generate-api.mjs --check && node scripts/generate-native.mjs --check && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "ext:build": "node extension/build.mjs",
    "ext:watch": "node extension/build.mjs --watch",
    "ext:check": "tsc -p extension/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hafley66/signals": "0.0.2",
    "@oddbird/css-anchor-positioning": "^0.9.0",
    "@react95/icons": "^2.5.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@tanstack/virtual-core": "^3.17.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^6.6.1",
    "dockview-core": "^6.6.1",
    "dompurify": "^3.4.11",
    "json-logic-js": "^2.0.5",
    "jsonata": "^2.2.2",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "rxjs": "^7.8.2",
    "shiki": "^4.2.0",
    "svg-pan-zoom": "^3.6.2",
    "tinykeys": "^4.0.0",
    "unified": "^11.0.5",
    "vega-embed": "^7.1.0",
    "xp.css": "^0.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2",
    "@types/chrome": "^0.2.2",
    "@types/json-logic-js": "^2.0.8",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/svg-pan-zoom": "^3.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.28.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
